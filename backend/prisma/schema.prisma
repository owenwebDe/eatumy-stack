// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  INVESTOR
  ADMIN
  SUPERADMIN
  BRANCH_MANAGER
}

enum Status {
  ACTIVE
  FROZEN
  INACTIVE
  MAINTENANCE
  LAUNCHING
}

enum ShareModel {
  UNITS
  PERCENT
}

enum WithdrawMode {
  MONTHLY_WINDOW
  ANYTIME
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  CANCELLED
}

enum KYCStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id         String    @id @default(cuid())
  role       Role      @default(INVESTOR)
  name       String
  mobile     String    @unique
  email      String?   @unique
  status     Status    @default(ACTIVE)
  kycStatus  KYCStatus @default(NOT_SUBMITTED)
  otp        String?
  otpExpires DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  bankAccounts    BankAccount[]
  investments     Investment[]
  ledgerEntries   ProfitLedger[]
  withdrawals     Withdrawal[]
  depositRequests DepositRequest[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  kycDocuments    KycDocument[]
  walletBalance   Float               @default(0)
  transactions    WalletTransaction[]

  branchManagerOf Hotel?
}

enum NotificationType {
  WELCOME
  DEPOSIT_REQUEST
  DEPOSIT_APPROVED
  DEPOSIT_REJECTED
  WITHDRAWAL_REQUEST
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  WITHDRAWAL_PAID
  BANK_VERIFICATION
  SHARE_PURCHASE_REQUEST
  KYC_SUBMISSION
  GENERAL
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
}

model KycDocument {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String   // e.g., 'ID Proof', 'Address Proof', 'Selfie'
  url        String   // URL or path to the document image/file
  uploadedAt DateTime @default(now())
  status     String   @default("PENDING") // PENDING, APPROVED, REJECTED
}

model Withdrawal {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  hotelId     String?
  hotel       Hotel?           @relation(fields: [hotelId], references: [id])
  amount      Float
  status      WithdrawalStatus @default(PENDING)
  requestedAt DateTime         @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  paidAt      DateTime?
  utr         String?
  remark      String?

  @@index([userId])
  @@index([hotelId])
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  SHARE_PURCHASE
  DIVIDEND
  TRANSACTION_FAILED
}

enum DepositStatus {
  PENDING
  APPROVED
  REJECTED
}

model DepositRequest {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  amount      Float
  status      DepositStatus @default(PENDING)
  referenceId String? // transaction ref
  createdAt   DateTime      @default(now())
  approvedAt  DateTime?
  rejectedAt  DateTime?

  @@index([userId])
}

model WalletTransaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  amount      Float
  type        TransactionType
  description String?
  referenceId String? // e.g., Investment ID or Admin ID
  created_at  DateTime        @default(now())

  @@index([userId])
}

model BankAccount {
  id            String             @id @default(cuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id])
  accountName   String
  accountNumber String // Encrypted
  ifsc          String
  bankName      String
  upiId         String?
  isDefault     Boolean            @default(false)
  status        VerificationStatus @default(PENDING)
  rejectionReason String?
  verifiedAt    DateTime?
  created_at    DateTime           @default(now())

  @@index([userId])
}

model Hotel {
  id                String       @id @default(cuid())
  name              String
  city              String
  address           String?
  logoUrl           String?
  status            Status       @default(ACTIVE)
  shareModel        ShareModel   @default(UNITS)
  totalUnits        Int?
  withdrawMode      WithdrawMode @default(MONTHLY_WINDOW)
  windowStartDay    Int?
  windowEndDay      Int?
  liveStreamEnabled Boolean      @default(false)
  liveStreamUrl     String?
  valuation         Float        @default(0)
  minInvestment     Float        @default(0)
  roi               String? // e.g. "18-24%"

  branchManagerId String? @unique
  branchManager   User?   @relation(fields: [branchManagerId], references: [id])

  created_at DateTime @default(now())

  investments    Investment[]
  dailyMetrics   DailyMetric[]
  monthlyProfits MonthlyProfit[]
  ledgerEntries  ProfitLedger[]
  withdrawals    Withdrawal[]
}

enum ShareRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Investment {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id])
  hotelId        String
  hotel          Hotel              @relation(fields: [hotelId], references: [id])
  investedAmount Float
  shareUnits     Int?
  sharePercent   Float?
  status         ShareRequestStatus @default(PENDING)
  approvedAt     DateTime?
  rejectedAt     DateTime?
  startDate      DateTime?
  created_at     DateTime           @default(now())

  @@index([userId])
  @@index([hotelId])
}

model DailyMetric {
  id          String   @id @default(cuid())
  hotelId     String
  hotel       Hotel    @relation(fields: [hotelId], references: [id])
  date        DateTime @default(now())
  ordersCount Int
  revenue     Float?
  expenses    Float?
  created_at  DateTime @default(now())

  @@unique([hotelId, date])
  @@index([hotelId])
}

model MonthlyProfit {
  id         String   @id @default(cuid())
  hotelId    String
  hotel      Hotel    @relation(fields: [hotelId], references: [id])
  month      DateTime // First day of the month
  netProfit  Float
  allocated  Boolean  @default(false)
  created_at DateTime @default(now())

  @@unique([hotelId, month])
  @@index([hotelId])
}

model ProfitLedger {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  hotelId         String
  hotel           Hotel    @relation(fields: [hotelId], references: [id])
  month           DateTime
  profitAllocated Float
  profitPaid      Float    @default(0)
  created_at      DateTime @default(now())

  @@unique([userId, hotelId, month])
  @@index([userId])
  @@index([hotelId])
}
model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  user        User     @relation(fields: [actorUserId], references: [id])
  action      String
  entityType  String
  entityId    String
  oldValue    Json?
  newValue    Json?
  created_at  DateTime @default(now())

  @@index([actorUserId])
}
